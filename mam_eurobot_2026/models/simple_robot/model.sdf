    <geometry>
      <mesh>
        <uri>meshes/roller_14_1.stl</uri>
        <scale>0.001 0.001 0.001</scale>
      </mesh>
    </geometry>

    <!-- Same friction model -->
    <surface>
      <friction>
        <ode>
          <mu>0.2</mu>
          <mu2>0.2</mu2>
        </ode>
      </friction>
    </surface>
  </collision>

</link>

