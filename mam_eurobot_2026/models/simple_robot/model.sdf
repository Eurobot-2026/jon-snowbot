<?xml version="1.0"?>
<sdf version="1.9">
  <model name="omni_like_robot" canonical_link="chassis">
    <pose>0 0 0 0 0 0</pose>

    <!-- CHASSIS -->
    <link name="chassis">
      <pose>0 0 0.05 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.07315</ixx>
          <iyy>0.151641</iyy>
          <izz>0.219727</izz>
          <ixy>-0.0</ixy>
          <iyz>0.0</iyz>
          <ixz>-2.7e-05</ixz>
        </inertia>
      </inertial>
      <visual name="chassis_visual">
        <geometry>
          <mesh>
            <uri>meshes/base_link.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.0 0.612 0.867 1</ambient>
          <diffuse>0.0 0.612 0.867 1</diffuse>
        </material>
      </visual>
      <collision name="chassis_collision">
        <geometry>
          <mesh>
            <uri>meshes/base_link.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- WHEELS -->

    <!-- FRONT LEFT -->
<link name="front_left_wheel">

  <!-- Position taken from old working chassis -->
  <pose>0 0 0.05 0 0 0</pose>

  <!-- Inertial from URDF -->
  <inertial>
    <!-- <pose>-2.1897287448918723e-05 -0.023738528231967565 3.1378817485983033e-06 0 0 0</pose> -->
    <mass>0.30282113324994747</mass>
    <inertia>
      <ixx>0.00016</ixx>
      <iyy>0.000181</iyy>
      <izz>0.000158</izz>
      <ixy>-1e-06</ixy>
      <iyz>0.0</iyz>
      <ixz>-0.0</ixz>
    </inertia>
  </inertial>

  <!-- Visual -->
  <visual name="visual">
    <!-- <pose>-0.125 -0.15 0 0 0 0</pose> -->
    <geometry>
      <mesh>
        <uri>meshes/wheel_frame_FL_1.stl</uri>
        <scale>0.001 0.001 0.001</scale>
      </mesh>
    </geometry>
    <material>
      <ambient>0.75 0.75 0.75 1</ambient>
      <diffuse>0.85 0.85 0.85 1</diffuse>
      <specular>0.9 0.9 0.9 1</specular>
    </material>
  </visual>

  <!-- Collision -->
  <collision name="collision">
    <!-- <pose>-0.125 -0.15 0 0 0 0</pose> -->
    <geometry>
      <mesh>
        <uri>meshes/wheel_frame_FL_1.stl</uri>
        <scale>0.001 0.001 0.001</scale>
      </mesh>
    </geometry>

    <!-- Friction model copied from working mecanum -->

    <surface>
      <friction>
        <ode>
          <mu>0.2</mu>
          <mu2>0.2</mu2>
        </ode>
      </friction>
    </surface>

  </collision>

</link>

<link name="roller_14_1">

  <!-- Keep all rollers consistent with wheel reference frame -->
  <pose>0 0 0.05 0 0 0</pose>

  <!-- Inertial (from URDF) -->
  <inertial>
    <mass>0.014233736590697255</mass>
    <inertia>
      <ixx>2e-06</ixx>
      <iyy>2e-06</iyy>
      <izz>2e-06</izz>
      <ixy>-1e-06</ixy>
      <iyz>-0.0</iyz>
