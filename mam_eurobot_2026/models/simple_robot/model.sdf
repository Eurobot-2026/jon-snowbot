        <uri>meshes/roller_14_1.stl</uri>
        <scale>0.001 0.001 0.001</scale>
      </mesh>
    </geometry>

    <!-- Same silver as wheels -->
    <material>
      <ambient>0.75 0.75 0.75 1</ambient>
      <diffuse>0.85 0.85 0.85 1</diffuse>
      <specular>0.9 0.9 0.9 1</specular>
    </material>
  </visual>

  <!-- Collision -->
